---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Vlad Ra — AI-First Product Leader">
  <header class="mb-16 flex items-center gap-5">
    <img src="/punk.png" alt="Vlad Ra" class="w-14 h-14 rounded-sm" />
    <div>
      <h1 class="mb-1">Vlad Ra</h1>
      <p class="text-text-label text-[0.72rem] uppercase tracking-[0.08em] font-medium">
        AI-First Product Leader<span class="hidden md:inline"> &middot; </span><br class="md:hidden" />Lisbon, Portugal
      </p>
    </div>
  </header>

  <section class="mb-14">
    <h2 class="mb-5">About</h2>
    <p class="mb-4">
      I help companies ship better products with smaller teams. I manage people and AI agents side by side — building modern workflows where Claude Code and agentic tools do the heavy lifting, and the team focuses on decisions that matter.
    </p>
    <p class="mb-4">
      I work end to end. Talk to users, outline specs, prompt and orchestrate AI agents, set up their environment, evaluate what comes back, test the final product. Same loop with the engineering team — I stay hands-on from discovery through shipping.
    </p>
    <p>
      I've led product across prediction markets, generative art, web3, ecommerce, games, and edtech. Startup generalist by background, systems thinker by instinct.
    </p>
  </section>

  <section class="mb-14">
    <h2 class="mb-5">Work</h2>
    <div class="space-y-3">
      <p>
        <strong><a href="https://trendle.fi" target="_blank" rel="noopener">Trendle</a></strong>
        <span class="text-text"> — </span>
        Prediction market for attention. Users trade on whether interest in a topic will rise or fall.
      </p>
      <p>
        <strong><a href="https://og.art" target="_blank" rel="noopener">OG.Art</a></strong>
        <span class="text-text"> — </span>
        Dynamic digital art platform. Generative NFT collections that mutated through user interaction. Millions in sales.
      </p>
      <p>
        <strong><a href="https://theoct.xyz" target="_blank" rel="noopener">The Oct</a></strong>
        <span class="text-text"> — </span>
        Massive multiplayer game across iOS, Android, web, and Telegram.
      </p>
      <p>
        <strong><a href="https://accuraten.com" target="_blank" rel="noopener">Accuraten</a></strong>
        <span class="text-text"> — </span>
        Co-founded. Digital agency — hundreds of projects, helped 20+ VCs with branding and online presence.
      </p>
    </div>
  </section>

  <section>
    <h2 class="mb-5">Contact</h2>
    <p>
      <a href="mailto:vlad19@gmail.com" class="mr-4">Email</a>
      <a href="https://www.linkedin.com/in/rafeev/" target="_blank" rel="noopener" class="mr-4">LinkedIn</a>
      <a href="https://github.com/dandaka" target="_blank" rel="noopener" class="mr-4">GitHub</a>
      <a href="https://x.com/dandaka" target="_blank" rel="noopener">X</a>
    </p>
  </section>
</Layout>
